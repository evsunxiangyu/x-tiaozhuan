{
  "manifest_version": 3,
  "name": "X 新标签页打开",
  "version": "1.2.0",
  "description": "在 X (Twitter) 中点击帖子或评论时，在新标签页打开而不是当前页跳转。支持一键开关。",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "X 新标签页打开 - 已启用（点击关闭）"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
